<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Health Connect 수면 데이터 읽기 권한 -->
    <uses-permission android:name="android.permission.health.READ_SLEEP_SESSION" />

    <!-- 알람 -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 진동 및 Wearable -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!--
        Health Connect 패키지 가시성 선언.
        Android 11 이상에서 Health Connect 앱 존재 여부 확인 및 권한 요청에 필요.
    -->
    <queries>
        <!-- Android 13 이하: 독립 앱 형태 Health Connect -->
        <package android:name="com.google.android.apps.healthdata" />
        <!-- Android 14+: OS 내장 Health Connect -->
        <package android:name="com.android.healthconnect.controller" />
        <!-- Samsung Galaxy 일부 기기 -->
        <package android:name="com.samsung.android.healthconnect" />
        <!-- 패키지명 무관하게 Health Connect intent 처리 가능한 앱 탐색 -->
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Smartwatch"
        tools:targetApi="31">

        <!-- 메인 화면 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 전체화면 알람 화면 (잠금화면 위 표시) -->
        <activity
            android:name=".AlarmActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:launchMode="singleTask"
            android:excludeFromRecents="true" />

        <!-- AlarmManager BroadcastReceiver -->
        <receiver
            android:name=".AlarmReceiver"
            android:exported="false" />

        <!--
            [필수] Health Connect 권한 사용 이유 화면.
            - Android 13 이하: ACTION_SHOW_PERMISSIONS_RATIONALE 처리
            - Android 14 이상: VIEW_PERMISSION_USAGE + HEALTH_PERMISSIONS 처리
            이 두 선언이 없으면 Health Connect 앱 권한 목록에 앱이 등록되지 않고
            permissionLauncher.launch()도 즉시 빈 결과를 반환합니다.
        -->
        <activity
            android:name=".HealthRationaleActivity"
            android:exported="true">
            <!-- Android 13 이하 -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Android 14 이상 -->
        <activity-alias
            android:name=".ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".HealthRationaleActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

    </application>

</manifest>
