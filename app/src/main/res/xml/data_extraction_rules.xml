<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API >= 31) 백업/이전 규칙.
    cloud-backup: 구글 드라이브 자동 백업
    device-transfer: 기기 변경 시 데이터 전송
    알람/수면 prefs는 양쪽 모두 제외 (다른 기기/시점에서 잘못 동작 방지).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="sleep_prefs.xml"/>
        <exclude domain="sharedpref" path="alarm_presets.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="sleep_prefs.xml"/>
        <exclude domain="sharedpref" path="alarm_presets.xml"/>
    </device-transfer>
</data-extraction-rules>
