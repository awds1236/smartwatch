<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 11 이하(API <= 30)용 자동 백업 규칙.
    알람/수면 관련 SharedPreferences는 다른 기기에서 복원 시 잘못된 시간에 울릴 수 있어 제외.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="sleep_prefs.xml"/>
    <exclude domain="sharedpref" path="alarm_presets.xml"/>
</full-backup-content>
