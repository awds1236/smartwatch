<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sleep_bg_dark"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="수면 알람"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/sleep_text_primary" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_manage"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="설정"
                android:scaleType="centerInside"
                android:tint="@color/sleep_text_primary" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="원하는 수면 시간을 설정하세요"
            android:textSize="14sp"
            android:textColor="@color/sleep_text_secondary"
            android:layout_marginBottom="32dp" />

        <!-- 목표 수면 시간 설정 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/sleep_bg_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="목표 수면 시간"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/sleep_text_primary"
                    android:layout_marginBottom="16dp" />

                <!-- 시간 선택 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="시간"
                            android:textSize="12sp"
                            android:textColor="@color/sleep_text_secondary"
                            android:layout_marginBottom="4dp" />

                        <NumberPicker
                            android:id="@+id/picker_hours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/sleep_text_primary"
                        android:paddingHorizontal="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="분"
                            android:textSize="12sp"
                            android:textColor="@color/sleep_text_secondary"
                            android:layout_marginBottom="4dp" />

                        <NumberPicker
                            android:id="@+id/picker_minutes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_goal_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/sleep_accent_coral"
                    android:layout_gravity="center_horizontal" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 기상 마감 시간 설정 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/sleep_bg_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="기상 마감 시간"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/sleep_text_primary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="이 시간까지 무조건 알람이 울립니다"
                    android:textSize="12sp"
                    android:textColor="@color/sleep_text_secondary"
                    android:layout_marginBottom="16dp" />

                <TimePicker
                    android:id="@+id/picker_deadline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:timePickerMode="spinner" />

                <TextView
                    android:id="@+id/tv_deadline_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/sleep_accent_coral"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 활성 알람 카드 (시계 앱 스타일) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_active_alarm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/sleep_bg_surface"
            app:strokeColor="@color/sleep_accent_coral"
            app:strokeWidth="1dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_lock_idle_alarm"
                        android:contentDescription="알람"
                        android:layout_marginEnd="8dp"
                        android:tint="@color/sleep_accent_coral" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="활성 알람"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/sleep_text_primary" />

                    <TextView
                        android:id="@+id/tv_alarm_active_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ON"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/sleep_bg_dark"
                        android:background="@drawable/badge_background"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="2dp" />
                </LinearLayout>

                <!-- 기상 마감 알람 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tv_alarm_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/sleep_text_primary"
                        android:fontFamily="sans-serif-light" />

                    <TextView
                        android:id="@+id/tv_alarm_ampm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="@color/sleep_text_secondary"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_alarm_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="기상 마감 알람"
                    android:textSize="13sp"
                    android:textColor="@color/sleep_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_alarm_remaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/sleep_accent_coral" />

                <!-- 수면 목표 알람 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/sleep_outline"
                    android:layout_marginVertical="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="수면 목표 달성 알람"
                            android:textSize="13sp"
                            android:textColor="@color/sleep_text_secondary" />

                        <TextView
                            android:id="@+id/tv_alarm_goal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/sleep_text_primary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="자동"
                        android:textSize="12sp"
                        android:textColor="@color/sleep_text_secondary" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 수면 상태 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/sleep_bg_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="현재 수면 상태"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/sleep_text_primary"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="모니터링 중지됨"
                    android:textSize="15sp"
                    android:textColor="@color/sleep_text_secondary" />

                <TextView
                    android:id="@+id/tv_sleep_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/sleep_text_secondary"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_deadline_countdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/sleep_accent_coral"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 수면 데이터 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_sleep_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/sleep_bg_surface"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Health Connect 수면 데이터"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/sleep_text_primary"
                    android:layout_marginBottom="16dp" />

                <!-- 수면 세션 시간 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="수면 시간 (세션)"
                        android:textSize="14sp"
                        android:textColor="@color/sleep_text_secondary" />

                    <TextView
                        android:id="@+id/tv_session_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/sleep_text_primary" />
                </LinearLayout>

                <!-- 실제 수면 시간 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="실제 수면 시간"
                        android:textSize="14sp"
                        android:textColor="@color/sleep_text_secondary" />

                    <TextView
                        android:id="@+id/tv_actual_sleep_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/sleep_accent_coral" />
                </LinearLayout>

                <!-- 차이 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp"
                    android:background="@color/sleep_bg_surface_variant">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="  차이 (AWAKE + OUT_OF_BED)"
                        android:textSize="13sp"
                        android:textColor="@color/sleep_text_secondary" />

                    <TextView
                        android:id="@+id/tv_sleep_diff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--  "
                        android:textSize="14sp"
                        android:textColor="@color/sleep_accent_coral" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Health Connect 권한 요청 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_permission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Health Connect 권한 허용"
            android:layout_marginBottom="12dp"
            android:textColor="@color/sleep_accent_coral"
            app:strokeColor="@color/sleep_accent_coral"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <!-- 모니터링 시작/중지 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_toggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="수면 모니터링 시작"
            android:textSize="16sp"
            android:textColor="@color/sleep_bg_dark"
            android:backgroundTint="@color/sleep_accent_coral"
            android:enabled="false" />

    </LinearLayout>
</ScrollView>
